AWS_REGION=us-east-1
DYNAMODB_TABLE_NAME=lambda-testcase-memory

# Cognito Authentication (required)
COGNITO_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=us-east-1

# Amazon Bedrock Guardrail (recommended — from CloudFormation stack outputs)
# These enable prompt attack filtering, content filtering, sensitive info redaction,
# and denied topic blocking on all Bedrock converse() calls.
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=